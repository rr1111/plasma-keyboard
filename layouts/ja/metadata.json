{
    "KPlugin": {
        "Id": "org.kde.plasma.keyboard.ja",
        "Name": "日本語"
    },
    "X-Plasma-Keyboard": {
        "Locales": [
            "ja_JP"
        ],
        "KeyboardLayouts": [
            {
                "Id": "romaji",
                "Name": "ローマ字",
                "Files": {
                    "main": "Romaji.qml",
                    "symbols": "shared/Symbols.qml",
                    "digits": "shared/Digits.qml",
                    "numbers": "shared/Numbers.qml",
                    "dialpad": "shared/Dialpad.qml"
                },
                "FormFactors": [
                    "phone",
                    "mediacenter",
                    "desktop"
                ]
            },
            {
                "Id": "twelvekey",
                "Name": "12キー",
                "Files": {
                    "main": "TwelveKey.qml",
                    "symbols": "shared/Symbols.qml",
                    "digits": "shared/Digits.qml",
                    "numbers": "shared/Numbers.qml",
                    "dialpad": "shared/Dialpad.qml"
                },
                "FormFactors": [
                    "phone",
                    "mediacenter",
                    "desktop"
                ]
            },
            {
                "Id": "full",
                "Name": "フルキーボード",
                "Files": {
                    "main": "Full.qml",
                    "symbols": "shared/Symbols.qml"
                },
                "FormFactors": [
                    "desktop"
                ]
            },
            {
                "Id": "full-extended",
                "Name": "拡張フルキーボード",
                "Files": {
                    "main": "FullExtended.qml",
                    "symbols": "shared/Symbols.qml"
                },
                "FormFactors": [
                    "desktop"
                ]
            }
        ]
    }
}
